    {
      "@type": "Organization",
      "@id": "https://www.relativity.com/",
      "name": "Relativity",
      "description": "Relativity is an eDiscovery and legal review platform offering RelativityOne, a cloud-based SaaS solution for managing the full legal data lifecycle.",
